# ===== Common =====
WALLET_DB_DSN=postgres://postgres:postgres@127.0.0.1:5432/wallet_saas?sslmode=disable
SCAN_DB_DSN=${WALLET_DB_DSN}

# ===== Service ports =====
WALLET_CORE_HOST=0.0.0.0
WALLET_CORE_PORT=8081
CHAIN_GATEWAY_ADDR=:8082
CHAIN_GATEWAY_GRPC_ADDR=:9082
SIGN_SERVICE_ADDR=127.0.0.1:9091

# ===== API gateway (optional) =====
WALLET_API_HTTP_ADDR=http://127.0.0.1:8081

# ===== Chain-gateway control-plane =====
CHAIN_GATEWAY_DB_DSN=${WALLET_DB_DSN}
CHAIN_GATEWAY_ENDPOINT_REFRESH_SECONDS=15
CHAIN_GATEWAY_ENDPOINT_PROBE_SECONDS=20
CHAIN_GATEWAY_ENDPOINT_FAIL_THRESHOLD=3
CHAIN_GATEWAY_ENDPOINT_OPEN_SECONDS=30

# Per-chain network preference for account plugins loaded from DB endpoints
CHAIN_GATEWAY_ACCOUNT_SOL_NETWORK=devnet
CHAIN_GATEWAY_ACCOUNT_TRON_NETWORK=nile
CHAIN_GATEWAY_ACCOUNT_APTOS_NETWORK=devnet
CHAIN_GATEWAY_ACCOUNT_COSMOS_NETWORK=sepolia
CHAIN_GATEWAY_ACCOUNT_SUI_NETWORK=testnet
CHAIN_GATEWAY_ACCOUNT_TON_NETWORK=testnet
CHAIN_GATEWAY_ACCOUNT_XLM_NETWORK=testnet
CHAIN_GATEWAY_ACCOUNT_BTT_NETWORK=testnet

# ===== Scanner =====
SCAN_INTERVAL_SECONDS=5
SCAN_ACCOUNT_PAGE_SIZE=20
SCAN_ACCOUNT_MAX_PAGES=2
SCAN_WATCH_LIMIT=500
SCAN_ADDR_CONCURRENCY=6
SCAN_REORG_WINDOW=6
SCAN_REORG_CANDIDATE_LIMIT=500
SCAN_REORG_NOT_FOUND_THRESHOLD=3
SCAN_OUTGOING_NOT_FOUND_THRESHOLD=3
SCAN_OUTGOING_NOT_FOUND_GRACE_SECONDS=45
SCAN_SWEEP_MIN_BALANCE=50
SCAN_WALLET_CORE_TIMEOUT_MS=10000
SCAN_CHAIN_GATEWAY_TIMEOUT_MS=10000

# ===== Optional callbacks =====
PROJECT_NOTIFY_BASE_URL=
PROJECT_NOTIFY_TOKEN=
PROJECT_NOTIFY_TIMEOUT_MS=5000
PROJECT_NOTIFY_CHAIN_ID_MAP=ethereum:sepolia=11155111,binance:testnet=97,polygon:amoy=80002,arbitrum:sepolia=421614,solana:devnet=901,tron:nile=3448148188
PROJECT_NOTIFY_DEFAULT_CHAIN_ID=0
